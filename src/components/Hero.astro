---
import design from "../../design.json";
import Button from "./Button.astro";
import Tag from "./Tag.astro";

const hero = design.layout.hero_section;
---

<section
  id="inicio"
  class="relative flex items-stretch overflow-hidden bg-white"
  style="margin-top: 80px; min-height: calc(100dvh - 80px);"
>
  <!-- Left column: content -->
  <div class="relative z-10 flex flex-col justify-center w-full lg:w-[52%] px-6 md:px-10 lg:px-16 xl:px-20 py-16 lg:py-0">
    <!-- Decorative background blob -->
    <div class="absolute -left-32 -top-32 w-96 h-96 bg-accent/8 rounded-full blur-3xl pointer-events-none"></div>

    <div class="animate-hero-in" style="animation-delay:0ms;">
      <Tag class="mb-5">ESPECIALISTAS EM JARDINS VERTICAIS</Tag>
    </div>

    <h1
      class="text-4xl sm:text-5xl lg:text-[3.4rem] xl:text-[4rem] font-bold tracking-tight text-text-dark leading-[1.09] mb-6 font-serif animate-hero-in"
      style="animation-delay:80ms;"
    >
      {hero.headline}
    </h1>

    <p
      class="text-base md:text-lg text-text-light mb-10 leading-relaxed max-w-xl animate-hero-in"
      style="animation-delay:160ms;"
    >
      {hero.subheadline}
    </p>

    <div
      class="flex flex-col sm:flex-row gap-4 mb-12 animate-hero-in"
      style="animation-delay:240ms;"
    >
      <a
        href={hero.buttons[0].link}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-3 bg-primary text-white px-7 py-4 rounded-full font-semibold text-sm hover:bg-primary-dark transition-all duration-300 shadow-lg shadow-primary/30 hover:shadow-primary/50 hover:-translate-y-0.5"
      >
        {hero.buttons[0].text}
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a
        href={hero.buttons[1].link}
        class="inline-flex items-center gap-2 border-2 border-primary/30 text-primary px-7 py-4 rounded-full font-semibold text-sm hover:border-primary hover:bg-primary/5 transition-all duration-300"
      >
        {hero.buttons[1].text}
      </a>
    </div>

    <!-- Stats row -->
    <div
      class="flex flex-wrap gap-8 pt-8 border-t border-gray-100 animate-hero-in"
      style="animation-delay:320ms;"
    >
      {
        hero.stats.map((stat) => (
          <div>
            <div class="text-2xl lg:text-3xl font-bold text-primary mb-0.5 font-serif">
              {stat.value}
            </div>
            <div class="text-xs font-medium text-text-light uppercase tracking-wider">
              {stat.label}
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Right column: image -->
  <div
    class="hidden lg:block lg:w-[48%] relative animate-hero-in"
    style="animation-delay:200ms;"
  >
    <!-- Main image fills right side -->
    <div class="absolute inset-0 overflow-hidden rounded-bl-[80px]">
      <img
        src="/images/hero.png"
        alt={hero.image_slider}
        class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-700"
      />
      <div class="absolute inset-0 bg-gradient-to-l from-transparent via-transparent to-white/10 pointer-events-none"></div>
    </div>

    <!-- Floating stats card -->
    <div class="absolute bottom-10 left-8 bg-white/95 backdrop-blur-sm rounded-2xl p-5 shadow-2xl border border-white max-w-[200px] animate-float">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-10 h-10 rounded-full bg-accent-light flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2d6a4f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
        </div>
        <div>
          <div class="text-lg font-bold text-primary">100%</div>
          <div class="text-xs text-text-light leading-tight">Plantas naturais</div>
        </div>
      </div>
      <div class="h-1.5 bg-accent-light rounded-full overflow-hidden">
        <div class="h-full bg-primary rounded-full" style="width:100%"></div>
      </div>
    </div>

    <!-- Decorative blobs -->
    <div class="absolute -z-10 bottom-0 right-0 w-72 h-72 bg-accent/15 rounded-full blur-3xl pointer-events-none"></div>
  </div>

  <!-- Mobile image (shown below content on small screens) -->
  <div class="lg:hidden absolute inset-0 -z-10">
    <img
      src="/images/hero.png"
      alt={hero.image_slider}
      class="w-full h-full object-cover opacity-10"
    />
  </div>
</section>

<style>
  @keyframes heroIn {
    from {
      opacity: 0;
      transform: translateY(22px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
  }

  .animate-hero-in {
    animation: heroIn 0.75s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    opacity: 0;
  }

  .animate-float {
    animation: float 4s ease-in-out infinite;
  }
</style>

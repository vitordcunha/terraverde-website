---
import design from "../../design.json";
import Button from "./Button.astro";
import Section from "./Section.astro";

const hero = design.layout.hero_section;
---

<section
  id="inicio"
  class="relative pt-20 pb-20 lg:pt-30 lg:pb-32 overflow-hidden bg-bg-light"
>
  <div class="container mx-auto px-4 md:px-6 lg:px-8 max-w-7xl relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      <!-- Content -->
      <div class="max-w-2xl">
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-text-dark leading-tight mb-6 animate-fade-in-up"
        >
          {hero.headline}
        </h1>
        <p
          class="text-lg md:text-xl text-text-light mb-8 leading-relaxed animate-fade-in-up"
          style="animation-delay: 100ms;"
        >
          {hero.subheadline}
        </p>

        <div
          class="flex flex-col sm:flex-row gap-4 mb-12 animate-fade-in-up"
          style="animation-delay: 200ms;"
        >
          <Button
            href={hero.buttons[0].link}
            style={hero.buttons[0].style as any}
          >
            {hero.buttons[0].text}
          </Button>
          <Button href={hero.buttons[1].link} style="outline">
            {hero.buttons[1].text}
          </Button>
        </div>

        <div
          class="grid grid-cols-3 gap-6 pt-8 border-t border-gray-200 animate-fade-in-up"
          style="animation-delay: 300ms;"
        >
          {
            hero.stats.map((stat) => (
              <div>
                <div class="text-3xl lg:text-4xl font-bold text-primary mb-1">
                  {stat.value}
                </div>
                <div class="text-sm font-medium text-text-light">
                  {stat.label}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Image -->
      <div
        class="relative lg:-mr-12 xl:-mr-24 animate-fade-in-up"
        style="animation-delay: 400ms;"
      >
        <div
          class="aspect-[4/5] md:aspect-square lg:aspect-[4/5] rounded-3xl overflow-hidden shadow-2xl relative"
        >
          <img
            src="/images/hero.png"
            alt={hero.image_slider}
            class="object-cover w-full h-full hover:scale-105 transition-transform duration-700"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent pointer-events-none"
          >
          </div>
        </div>

        <!-- Decorative blob -->
        <div
          class="absolute -z-10 -bottom-12 -left-12 w-64 h-64 bg-accent/20 rounded-full blur-3xl"
        >
        </div>
        <div
          class="absolute -z-10 -top-12 -right-12 w-64 h-64 bg-primary/10 rounded-full blur-3xl"
        >
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
    transform: translateY(20px);
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

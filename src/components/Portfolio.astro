---
import Section from './Section.astro';
import Tag from './Tag.astro';
import Button from './Button.astro';

const filters = [
  { label: "Todos", value: "all" },
  { label: "Residencial", value: "residencial" },
  { label: "Comercial", value: "comercial" },
  { label: "Corporativo", value: "corporativo" },
  { label: "Externo", value: "externo" }
];

const projects = [
  { id: 1, category: "residencial", title: "Apartamento Varanda", image: "https://images.unsplash.com/photo-1584727638096-042c45049ebe?q=80&w=800&auto=format&fit=crop" },
  { id: 2, category: "comercial", title: "Restaurante Verdi", image: "https://images.unsplash.com/photo-1555396273-367ea4eb4db5?q=80&w=800&auto=format&fit=crop" },
  { id: 3, category: "corporativo", title: "Escritório Central", image: "https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=800&auto=format&fit=crop" },
  { id: 4, category: "externo", title: "Jardim de Inverno", image: "https://images.unsplash.com/photo-1589923188900-85dae523342b?q=80&w=800&auto=format&fit=crop" },
  { id: 5, category: "residencial", title: "Cobertura Sul", image: "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?q=80&w=800&auto=format&fit=crop" },
  { id: 6, category: "comercial", title: "Café Botânico", image: "https://images.unsplash.com/photo-1554118811-1e0d58224f24?q=80&w=800&auto=format&fit=crop" }
];
---

<Section id="portfolio" class="bg-white">
  <div class="text-center mb-12 max-w-3xl mx-auto">
    <Tag class="mb-4">PORTFÓLIO</Tag>
    <h2 class="text-3xl md:text-4xl font-bold text-text-dark mb-6">
      Projetos que Falam por Si
    </h2>
    <p class="text-text-light text-lg">
      Cada jardim conta uma história. Veja alguns dos nossos projetos realizados em residências, empresas e espaços comerciais em Porto Alegre e região.
    </p>
  </div>

  <div class="flex flex-wrap justify-center gap-2 md:gap-4 mb-12">
    {filters.map((filter, index) => (
      <button 
        class={`filter-btn px-6 py-2 rounded-full font-medium transition-all duration-300 ${index === 0 ? 'bg-primary text-white' : 'bg-bg-light text-text-light hover:bg-bg-light/80'}`}
        data-filter={filter.value}
      >
        {filter.label}
      </button>
    ))}
  </div>

  <div class="flex flex-wrap justify-center gap-6 mb-16" id="portfolio-grid">
    {projects.map((project) => (
      <div class="portfolio-item group relative rounded-xl overflow-hidden aspect-[4/3] w-full md:w-[calc(50%-1.5rem)] lg:w-[calc(33.333%-1.5rem)]" data-category={project.category}>
        <img 
          src={project.image} 
          alt={project.title}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
          <span class="text-white/80 text-sm font-medium uppercase tracking-wider mb-2">{project.category}</span>
          <h3 class="text-white text-xl font-bold">{project.title}</h3>
        </div>
      </div>
    ))}
  </div>

  <div class="text-center">
    <Button href="https://wa.me/message/UFIXHURQVOMGD1" style="primary" target="_blank">QUERO UM PROJETO ASSIM</Button>
  </div>
</Section>

<script>
  // Simple filtering logic
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const portfolioItems = document.querySelectorAll('.portfolio-item');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Active state
        filterBtns.forEach(b => {
          b.classList.remove('bg-primary', 'text-white');
          b.classList.add('bg-bg-light', 'text-text-light');
        });
        btn.classList.add('bg-primary', 'text-white');
        btn.classList.remove('bg-bg-light', 'text-text-light');

        const filter = btn.getAttribute('data-filter');

        portfolioItems.forEach(item => {
          if (filter === 'all' || item.getAttribute('data-category') === filter) {
            (item as HTMLElement).style.display = 'block';
            setTimeout(() => {
              (item as HTMLElement).style.opacity = '1';
              (item as HTMLElement).style.transform = 'scale(1)';
            }, 10);
          } else {
            (item as HTMLElement).style.opacity = '0';
            (item as HTMLElement).style.transform = 'scale(0.95)';
            setTimeout(() => {
              (item as HTMLElement).style.display = 'none';
            }, 300);
          }
        });
      });
    });
  });
</script>

---
import Section from './Section.astro';
import Tag from './Tag.astro';

const steps = [
  {
    step: "01",
    title: "Fale comigo no WhatsApp",
    description: "Me conte sobre o seu espaço e o que você está imaginando. Sem compromisso, sem burocracia."
  },
  {
    step: "02",
    title: "Visita e projeto personalizado",
    description: "Vou até você, avalio o espaço e apresento um projeto com as melhores espécies e soluções para o ambiente."
  },
  {
    step: "03",
    title: "Execução com plantas naturais",
    description: "Nossa equipe realiza a instalação com cuidado e precisão, utilizando apenas plantas e materiais de qualidade."
  },
  {
    step: "04",
    title: "Acompanhamento e manutenção",
    description: "Você não fica sozinho depois. Oferecemos orientação e serviço de manutenção para seu jardim durar muito."
  }
];
---

<Section id="como-funciona" class="bg-bg-light overflow-hidden">
  <div class="text-center mb-16 max-w-3xl mx-auto">
    <Tag class="mb-4">COMO FUNCIONA</Tag>
    <h2 class="text-3xl md:text-4xl font-bold text-text-dark mb-6">
      Do Primeiro Contato ao Jardim Pronto
    </h2>
    <p class="text-text-light text-lg">
      Um processo simples, transparente e totalmente personalizado para você.
    </p>
  </div>

  <div class="relative max-w-5xl mx-auto">
    <!-- Desktop connecting line -->
    <div class="hidden md:block absolute top-[40px] left-[12%] w-[76%] h-0.5 bg-primary/20 z-0"></div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-6 relative z-10">
      {steps.map((step, index) => (
        <div class="flex flex-col items-center text-center group">
          <div class="w-20 h-20 rounded-full bg-white border-4 border-primary text-primary flex items-center justify-center text-2xl font-bold mb-6 shadow-lg group-hover:scale-110 group-hover:bg-primary group-hover:text-white transition-all duration-300">
            {step.step}
          </div>
          <h3 class="text-xl font-bold text-text-dark mb-3">
            {step.title}
          </h3>
          <p class="text-text-light leading-relaxed">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</Section>

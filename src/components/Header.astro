---
import design from '../../design.json';
import Icon from './Icon.astro';

const header = design.layout.header;
---

<header class="fixed w-full top-0 z-50 transition-all duration-300" id="main-header">
  <div class="container mx-auto px-4 md:px-6 lg:px-8 max-w-7xl">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="#inicio" class="flex items-center gap-2.5 font-bold text-primary tracking-tight text-xl group">
        <div class="w-9 h-9 bg-primary rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
        </div>
        <span class="font-serif">{header.logo}</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        <ul class="flex gap-1">
          {header.navigation.map((item) => (
            <li>
              <a
                href={item.link}
                class="px-4 py-2 text-sm font-medium text-text-light hover:text-primary rounded-lg hover:bg-primary/5 transition-all duration-200"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- CTA + Mobile -->
      <div class="flex items-center gap-3">
        <a
          href="https://wa.me/message/UFIXHURQVOMGD1"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden lg:inline-flex items-center gap-2 bg-primary text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-primary-dark transition-all duration-300 shadow-md shadow-primary/20 hover:shadow-primary/40 hover:-translate-y-px"
        >
          {header.cta_button}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </a>

        <!-- Mobile Burger -->
        <button id="mobile-menu-btn" class="lg:hidden text-text-dark p-2 rounded-lg hover:bg-gray-100 transition-colors" aria-label="Menu">
          <Icon name="menu" class="w-5 h-5" />
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="fixed inset-0 bg-white z-40 translate-x-full transition-transform duration-300 flex flex-col pt-24 pb-8 px-6 lg:hidden">
    <button id="mobile-close-btn" class="absolute top-5 right-4 text-text-dark p-2 rounded-lg hover:bg-gray-100" aria-label="Close menu">
      <Icon name="x" class="w-5 h-5" />
    </button>
    <nav class="flex-1 flex flex-col gap-6">
      <ul class="flex flex-col gap-2">
        {header.navigation.map((item) => (
          <li>
            <a
              href={item.link}
              class="mobile-link text-text-dark hover:text-primary block py-3 px-4 rounded-xl hover:bg-primary/5 text-lg font-medium transition-colors"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <div class="mt-auto space-y-4">
        <a
          href="https://wa.me/message/UFIXHURQVOMGD1"
          target="_blank"
          class="mobile-link flex items-center justify-center gap-2 bg-primary text-white w-full py-3.5 rounded-full font-semibold hover:bg-primary-dark transition"
        >
          {header.cta_button}
        </a>
        <div class="pt-4 border-t border-gray-100 text-text-light text-sm space-y-2">
          <p class="flex items-center gap-2"><Icon name="map-pin" class="w-4 h-4 text-primary" /> Porto Alegre/RS</p>
          <p class="flex items-center gap-2"><Icon name="whatsapp" class="w-4 h-4 text-primary" /> {header.contact_info.phone}</p>
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-close-btn');
  const menu = document.getElementById('mobile-menu');
  const links = document.querySelectorAll('.mobile-link');
  const header = document.getElementById('main-header');

  const toggleMenu = () => {
    menu?.classList.toggle('translate-x-full');
    document.body.classList.toggle('overflow-hidden');
  };

  btn?.addEventListener('click', toggleMenu);
  closeBtn?.addEventListener('click', toggleMenu);
  links.forEach(link => link.addEventListener('click', toggleMenu));

  // Header scroll behaviour
  const updateHeader = () => {
    if (window.scrollY > 20) {
      header?.classList.add('bg-white/95', 'backdrop-blur-md', 'shadow-sm', 'border-b', 'border-gray-100');
      header?.classList.remove('bg-transparent');
    } else {
      header?.classList.remove('bg-white/95', 'backdrop-blur-md', 'shadow-sm', 'border-b', 'border-gray-100');
      header?.classList.add('bg-transparent');
    }
  };

  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });
</script>

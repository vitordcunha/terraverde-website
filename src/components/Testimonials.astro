---
import Tag from './Tag.astro';

const testimonials = [
  {
    name: "Ana Paula M.",
    type: "Cliente residencial",
    text: "A Carmen transformou a parede da minha sala em algo que nunca imaginei que seria possível. O jardim vertical ficou simplesmente incrível — parece que o apartamento ganhou vida.",
    rating: 5,
    avatar: "AP"
  },
  {
    name: "Arq. Rodrigo S.",
    type: "Arquiteto parceiro",
    text: "Indico a Terra Verde para todos os meus clientes que querem jardim vertical. Técnica impecável, prazo cumprido e as plantas são sempre lindas e saudáveis.",
    rating: 5,
    avatar: "RS"
  },
  {
    name: "Restaurante Verdi",
    type: "Cliente comercial",
    text: "Contratamos a Carmen para o jardim vertical do nosso restaurante e virou o ponto mais fotografado do espaço. Os clientes amam e o ambiente ficou muito mais aconchegante.",
    rating: 5,
    avatar: "RV"
  }
];
---

<section class="bg-white py-20 lg:py-28 reveal">
  <div class="container mx-auto px-4 md:px-6 lg:px-8 max-w-7xl">
    <div class="text-center mb-14 max-w-2xl mx-auto">
      <Tag class="mb-4">DEPOIMENTOS</Tag>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text-dark mb-5 leading-tight font-serif">
        O Que Nossos Clientes Dizem
      </h2>
      <p class="text-text-light text-base leading-relaxed">
        Nada melhor do que a experiência de quem já transformou seu espaço com a Terra Verde.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {testimonials.map((item) => (
        <div class="group bg-bg-section hover:bg-white hover:shadow-xl rounded-2xl p-7 border border-transparent hover:border-gray-100 transition-all duration-300 flex flex-col">
          <!-- Stars -->
          <div class="flex gap-1 mb-5">
            {Array.from({ length: item.rating }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#52b788" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            ))}
          </div>

          <!-- Quote mark -->
          <div class="text-4xl text-primary/15 font-serif font-bold leading-none mb-3 select-none">"</div>

          <p class="text-text-dark text-sm leading-relaxed flex-grow mb-6 font-medium">
            {item.text}
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-5 border-t border-gray-100">
            <div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center text-xs font-bold flex-shrink-0">
              {item.avatar}
            </div>
            <div>
              <p class="font-bold text-text-dark text-sm">{item.name}</p>
              <p class="text-xs text-text-light">{item.type}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

---
import Section from './Section.astro';
import Tag from './Tag.astro';

const testimonials = [
  {
    name: "Ana Paula M.",
    type: "Cliente residencial",
    text: "A Carmen transformou a parede da minha sala em algo que nunca imaginei que seria possível. O jardim vertical ficou simplesmente incrível — parece que o apartamento ganhou vida.",
    rating: 5
  },
  {
    name: "Arq. Rodrigo S.",
    type: "Arquiteto parceiro",
    text: "Indico a Terra Verde para todos os meus clientes que querem jardim vertical. Técnica impecável, prazo cumprido e as plantas são sempre lindas e saudáveis.",
    rating: 5
  },
  {
    name: "Restaurante Verdi",
    type: "Cliente comercial",
    text: "Contratamos a Carmen para o jardim vertical do nosso restaurante e virou o ponto mais fotografado do espaço. Os clientes amam e o ambiente ficou muito mais aconchegante.",
    rating: 5
  }
];
---

<Section class="bg-primary/5">
  <div class="text-center mb-16 max-w-3xl mx-auto">
    <Tag class="mb-4">DEPOIMENTOS</Tag>
    <h2 class="text-3xl md:text-4xl font-bold text-text-dark mb-6">
      O Que Nossos Clientes Dizem
    </h2>
    <p class="text-text-light text-lg">
      Nada melhor do que a experiência de quem já transformou seu espaço com a Terra Verde.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
    {testimonials.map((item) => (
      <div class="bg-white p-8 rounded-2xl shadow-sm border border-primary/10 relative">
        <div class="absolute top-6 right-8 text-primary/10">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
        </div>
        
        <div class="flex gap-1 mb-6">
          {Array.from({ length: item.rating }).map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#52b788" stroke="#52b788" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          ))}
        </div>
        
        <p class="text-text-light italic mb-8 relative z-10 text-lg">
          "{item.text}"
        </p>
        
        <div>
          <p class="font-bold text-text-dark">{item.name}</p>
          <p class="text-sm text-text-light">{item.type}</p>
        </div>
      </div>
    ))}
  </div>
</Section>

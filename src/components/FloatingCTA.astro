---
import design from '../../design.json';
import Icon from './Icon.astro';

const link = design.layout.hero_section.buttons[0].link; // WhatsApp link
---

<a 
  href={link} 
  target="_blank" 
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 lg:bottom-10 lg:right-10 z-50 bg-[#25D366] text-white p-4 rounded-full shadow-[0_8px_30px_rgb(37,211,102,0.4)] hover:scale-110 hover:-translate-y-2 transition-all duration-300 flex items-center justify-center group"
  aria-label="Falar no WhatsApp"
>
  <Icon name="whatsapp" class="w-8 h-8" />
  
  <!-- Tooltip that shows on hover -->
  <span class="absolute right-full mr-4 bg-white text-text-dark text-sm font-semibold px-4 py-2 rounded-xl shadow-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none whitespace-nowrap">
    Fale com a Carmen
  </span>
  
  <!-- Pulse animation -->
  <span class="absolute inset-0 rounded-full bg-[#25D366] animate-ping opacity-20 -z-10"></span>
</a>

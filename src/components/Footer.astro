---
import Section from './Section.astro';
---

<footer class="bg-text-dark text-white pt-16 pb-8 border-t border-white/10" id="contato">
  <div class="container mx-auto px-4 md:px-6 lg:px-8 max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- Brand & Tagline -->
      <div class="col-span-1 md:col-span-2 lg:col-span-1">
        <a href="#" class="text-2xl font-bold font-serif mb-4 block text-white hover:text-accent transition-colors">
          Terra Verde & Co
        </a>
        <p class="text-white/70 mb-6 leading-relaxed">
          Natureza viva para espaços únicos.
        </p>
        <div class="flex gap-4">
          <a href="https://instagram.com/terraverde.co" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-accent hover:scale-110 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
            <span class="sr-only">Instagram</span>
          </a>
          <a href="https://www.facebook.com/terraverde.co" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-accent hover:scale-110 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
            <span class="sr-only">Facebook</span>
          </a>
          <a href="https://wa.me/message/UFIXHURQVOMGD1" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-accent hover:scale-110 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <span class="sr-only">WhatsApp</span>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-white font-bold mb-6 text-lg">Links Rápidos</h4>
        <ul class="space-y-3">
          {["Início", "Jardim Vertical", "Serviços", "Portfólio", "Sobre nós", "Contato"].map((item, i) => (
            <li>
              <a href={['#inicio', '#jardim-vertical', '#servicos', '#portfolio', '#sobre', '#contato'][i]} class="text-white/70 hover:text-white transition-colors flex items-center gap-2 group">
                <span class="w-1.5 h-1.5 rounded-full bg-accent opacity-0 group-hover:opacity-100 transition-opacity"></span>
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="col-span-1 md:col-span-2 lg:col-span-2">
        <h4 class="text-white font-bold mb-6 text-lg">Contato e Endereço</h4>
        <ul class="space-y-4">
          <li class="flex items-start gap-4">
            <div class="mt-1 text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 15 4 10a8 8 0 0 1 16 0"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <p class="text-white/70 leading-relaxed">
              Rua Juncal, nº 40 - Jardim Europa,<br>Porto Alegre/RS
            </p>
          </li>
          <li class="flex items-center gap-4">
            <div class="text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <a href="https://wa.me/message/UFIXHURQVOMGD1" target="_blank" rel="noopener noreferrer" class="text-white/70 hover:text-white transition-colors">
              51 99833-5980
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-white/50 text-sm text-center md:text-left">
        © 2025 Terra Verde & Co. Todos os direitos reservados.
      </p>
      <div class="flex gap-4">
        <a href="#" class="text-white/50 hover:text-white text-sm transition-colors">Política de Privacidade</a>
        <a href="#" class="text-white/50 hover:text-white text-sm transition-colors">Termos de Uso</a>
      </div>
    </div>
  </div>
</footer>

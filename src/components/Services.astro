---
import Section from './Section.astro';
import Tag from './Tag.astro';

const services = [
  {
    title: "Jardim Vertical Natural",
    description: "Nossa especialidade. Projeto, execução e acompanhamento com plantas 100% naturais.",
    image: "https://images.unsplash.com/photo-1598460655827-0c2d3a77d1cf?q=80&w=800&auto=format&fit=crop",
    highlighted: true
  },
  {
    title: "Consultoria e Projetos",
    description: "Projetos paisagísticos personalizados para arquitetos, designers e construtoras.",
    image: "https://images.unsplash.com/photo-1584725906806-a669ff81fcee?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Execução de Jardins",
    description: "Do pequeno jardim residencial ao grande projeto comercial.",
    image: "https://images.unsplash.com/photo-1558904541-efa843a96f1d?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Manutenção de Jardins",
    description: "Serviço periódico de manutenção especializada para seu jardim durar anos.",
    image: "https://images.unsplash.com/photo-1416879590825-9f5b2b2b10ab?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Plantas para Interior",
    description: "Melhores espécies para interiores, combinando estética e adaptabilidade.",
    image: "https://images.unsplash.com/photo-1545241047-6083a36a0d1d?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Cursos e Workshops",
    description: "Técnicas de paisagismo e montagem de jardins verticais em cursos presenciais.",
    image: "https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Empório Garden",
    description: "Loja com plantas, substratos, vasos e acessórios selecionados.",
    image: "https://images.unsplash.com/photo-1466692476868-aef1dfb1e735?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Eventos e Exposições",
    description: "Instalações verdes para eventos corporativos, casamentos e feiras.",
    image: "https://images.unsplash.com/photo-1510265236756-11da9261eb8a?q=80&w=800&auto=format&fit=crop"
  }
];
---

<section id="servicos" class="bg-white py-20 lg:py-28 reveal">
  <div class="container mx-auto px-4 md:px-6 lg:px-8 max-w-7xl">
    <!-- Header row -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-14">
      <div class="max-w-xl">
        <Tag class="mb-4">NOSSOS SERVIÇOS</Tag>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text-dark leading-tight font-serif">
          Soluções Verdes Para Cada Espaço
        </h2>
      </div>
      <div class="lg:max-w-sm">
        <p class="text-text-light text-base leading-relaxed mb-6">
          Além dos jardins verticais, oferecemos uma gama completa de serviços para transformar e cuidar dos seus espaços verdes.
        </p>
        <a
          href="#contato"
          class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-full font-semibold text-sm hover:bg-primary-dark transition-all duration-300 shadow-md shadow-primary/20 hover:-translate-y-px"
        >
          VER TODOS OS SERVIÇOS
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <!-- Image grid — 4 cols like Lawnc -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {services.map((service, i) => (
        <div class={`group relative rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-400 cursor-pointer ${service.highlighted ? 'sm:col-span-1 lg:col-span-1' : ''}`}>
          <!-- Image -->
          <div class="relative h-52 overflow-hidden">
            <img
              src={service.image}
              alt={service.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
            <!-- Gradient overlay always visible slightly, stronger on hover -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>

            {service.highlighted && (
              <div class="absolute top-3 left-3 bg-primary text-white text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wide">
                Destaque
              </div>
            )}
          </div>

          <!-- Content -->
          <div class="p-5 bg-white group-hover:bg-bg-section transition-colors duration-300">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="font-bold text-text-dark text-base mb-1.5 group-hover:text-primary transition-colors font-serif leading-snug">
                  {service.title}
                </h3>
                <p class="text-text-light text-xs leading-relaxed line-clamp-2">
                  {service.description}
                </p>
              </div>
              <!-- Arrow icon -->
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center group-hover:bg-primary transition-colors duration-300 mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

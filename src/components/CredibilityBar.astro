---
import design from '../../design.json';
import Icon from './Icon.astro';

const data = design.layout.credibility_bar.items;
---

<div class="bg-primary text-white py-8 lg:py-10">
  <div class="container mx-auto px-4 md:px-6 lg:px-8 max-w-7xl">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {data.map((item) => (
        <div class="flex items-center gap-4 group">
          <div class="flex-shrink-0 w-12 h-12 flex items-center justify-center rounded-full bg-white/10 group-hover:bg-accent/30 transition-colors duration-300">
            <Icon name={item.icon} class="w-6 h-6 text-accent" />
          </div>
          <p class="font-medium text-sm md:text-base leading-snug">
            {item.text}
          </p>
        </div>
      ))}
    </div>
  </div>
</div>

---
import design from '../../design.json';
import Icon from './Icon.astro';

const data = design.layout.credibility_bar.items;
---

<div class="bg-bg-section border-y border-gray-100 py-7">
  <div class="container mx-auto px-4 md:px-6 lg:px-8 max-w-7xl">
    <div class="flex flex-wrap justify-center md:justify-between items-center gap-6 lg:gap-8">
      {data.map((item) => (
        <div class="flex items-center gap-3 group">
          <div class="flex-shrink-0 w-9 h-9 flex items-center justify-center rounded-xl bg-accent/15 group-hover:bg-primary group-hover:scale-105 transition-all duration-300">
            <Icon name={item.icon} class="w-4 h-4 text-primary group-hover:text-white transition-colors" />
          </div>
          <p class="font-medium text-sm text-text-dark whitespace-nowrap">
            {item.text}
          </p>
        </div>
      ))}
    </div>
  </div>
</div>

---
interface Props {
  id?: string;
  class?: string;
  theme?: 'light' | 'dark' | 'primary';
  padding?: 'small' | 'normal' | 'large' | 'none';
}

const { 
  id, 
  class: className = '', 
  theme = 'light',
  padding = 'normal'
} = Astro.props;

const themes = {
  light: 'bg-bg-light',
  dark: 'bg-text-dark text-white',
  primary: 'bg-primary text-white'
};

const paddings = {
  none: '',
  small: 'py-8 md:py-12',
  normal: 'py-16 md:py-24',
  large: 'py-24 md:py-32'
};

const classes = `${themes[theme]} ${paddings[padding]} ${className}`;
---

<section id={id} class={`${classes} reveal`}>
  <div class="container mx-auto px-4 md:px-6 lg:px-8 max-w-7xl">
    <slot />
  </div>
</section>
